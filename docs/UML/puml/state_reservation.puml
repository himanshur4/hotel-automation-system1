@startuml state_reservation
title Reservation State-Chart
skinparam shadowing false
skinparam state {
  BackgroundColor      #E2EFDA
  BorderColor          #1F3864
  ArrowColor           #1F3864
  FontColor            #1F3864
  StartColor           #1F3864
  EndColor             #1F3864
}

[*] --> Active : allocateRoom()
state Active : guest is checked in
state CheckedOut : bill generated, room released

Active --> Active : recordCateringOrder() [tokenValid]
Active --> CheckedOut : processCheckOut()
CheckedOut --> [*]
@enduml